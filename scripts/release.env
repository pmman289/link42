# Copy to scripts/release.env and edit for your environment.
#
# The publish scripts load scripts/release.env automatically when it exists.
# Environment variables passed on the command line still take precedence:
#   LINK42_PUBLIC_HOST=other-host scripts/agent/publish-public-assets.sh

# SSH target for public static assets.
LINK42_PUBLIC_HOST=rcvps

# Web root on the public static asset server.
LINK42_PUBLIC_ROOT=/opt/1panel/www/sites/get.pmman.tech/index

# Public base URL corresponding to LINK42_PUBLIC_ROOT.
LINK42_PUBLIC_BASE_URL=https://get.pmman.tech

# Docker image repository.
IMAGE_REPO=pmman/link42
