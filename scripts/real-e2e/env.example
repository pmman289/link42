# Copy to /tmp/link42-real-e2e.env or export the variables before running.

# Local controller.
LINK42_REAL_RUN_DIR=/tmp/link42-real-e2e
LINK42_REAL_DB=/tmp/link42-real-e2e/link42.db
LINK42_REAL_HOST=0.0.0.0
LINK42_REAL_PORT=8016

# Two-node real-machine topology.
LINK42_REAL_LOCAL_NODE_NAME=real-local
LINK42_REAL_REMOTE_NODE_NAME=real-remote
LINK42_REAL_LOCAL_ENDPOINT=192.0.2.10
LINK42_REAL_REMOTE_ENDPOINT=198.51.100.20
LINK42_REAL_REMOTE_SSH=remote-test-host

# Controller URL as seen by each agent.
LINK42_REAL_LOCAL_AGENT_URL=http://127.0.0.1:8016
LINK42_REAL_REMOTE_AGENT_URL=http://192.0.2.10:8016

# Agent runtime.
LINK42_REAL_POLL_INTERVAL=2

# Optional cleanup hints for generated WireGuard test interfaces.
# Add every interface name a real test may create here.
LINK42_REAL_LOCAL_WG_IFACES=
LINK42_REAL_REMOTE_WG_IFACES=

# Optional middleware cleanup hints.
# Add bind interfaces used by mimic tests, for example "enp3s0".
LINK42_REAL_LOCAL_MIMIC_IFACES=
LINK42_REAL_REMOTE_MIMIC_IFACES=

# Set to 1 when this test run installed mimic packages and they should be purged.
LINK42_REAL_PURGE_MIMIC=0
